<body class="<%= controller_name %>">

  <div class="container">

    <!-- 日付 -->
    <div class="date">
      <%= Date.today.strftime("%Y-%m-%d (%a)") %>
    </div>

    <!-- 現在時刻（JSで更新予定） -->
    <div class="current-time" id="current-time">
      --:--:-- 
    </div>

    <hr>

    <!-- 打刻状況表示 -->
    <div class="status">
      <div class="status-labels">
        <div>出勤時刻</div>
        <div>退勤時刻</div>
      </div>

      <div class="status-times">
        <div>
          <%= @attendance&.start_time ? @attendance.start_time.strftime("%H:%M") : "未打刻" %>
        </div>
        <div>
          <%= @attendance&.end_time ? @attendance.end_time.strftime("%H:%M") : "未打刻" %>
        </div>
      </div>
    </div>

    <hr>

    <!-- 打刻ボタン -->
    <div class="buttons">
      <div class="button-row">
        <%= button_to "出勤", clock_in_attendances_path, method: :post, class: "btn" %>
        <%= button_to "退勤", clock_out_attendances_path, method: :post, class: "btn" %>
      </div>

      <div class="button-row">
          <%= button_to "定時出勤", setting_clock_in_attendances_path, disabled: @setting.default_start_time.blank? %>
          
          <%= button_to "定時退勤 ", setting_clock_out_attendances_path, disabled: @setting.default_end_time.blank? %>
      </div>
    </div>

    <hr>

    <!-- メッセージ表示エリア -->
    <div class="flash-area">
      <% if flash[:notice] %>
        <div class="flash-notice">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <% if flash[:warning] %>
        <div class="flash-warning">
          <%= flash[:warning] %>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="flash-alert">
          <%= flash[:alert] %>
        </div>
      <% end %>
    </div>

  </div>
</body>